# Tutorial Debug profile: richer logs and diagnostics for learning.
CONFIG_NRF24_MODE_TUTORIAL_DEBUG=y
# CONFIG_NRF24_MODE_RELEASE_LITE is not set

CONFIG_NRF24_ROLE_TX=y
# CONFIG_NRF24_ROLE_RX is not set

CONFIG_NRF24_SPI_HOST=2
CONFIG_NRF24_PIN_MOSI=13
CONFIG_NRF24_PIN_MISO=12
CONFIG_NRF24_PIN_SCK=14
CONFIG_NRF24_PIN_CSN=11
CONFIG_NRF24_PIN_CE=10
CONFIG_NRF24_PIN_IRQ=3

CONFIG_NRF24_CHANNEL=40
CONFIG_NRF24_PAYLOAD_SIZE=32
CONFIG_NRF24_DATA_RATE_250K=y
# CONFIG_NRF24_DATA_RATE_1M is not set
# CONFIG_NRF24_DATA_RATE_2M is not set
CONFIG_NRF24_PA_12DBM=y
# CONFIG_NRF24_PA_18DBM is not set
# CONFIG_NRF24_PA_6DBM is not set
# CONFIG_NRF24_PA_0DBM is not set

CONFIG_NRF24_ADDR_WIDTH=5
CONFIG_NRF24_PIPE0_ADDR="E7E7E7E7E7"
CONFIG_NRF24_PIPE1_ADDR="C2C2C2C2C2"
CONFIG_NRF24_TX_ADDR="E7E7E7E7E7"
CONFIG_NRF24_ENABLE_PIPE1=y

CONFIG_NRF24_AUTO_RETR_DELAY_US=750
CONFIG_NRF24_AUTO_RETR_COUNT=10
CONFIG_NRF24_TX_PERIOD_MS=1000
CONFIG_NRF24_TX_POWER_SAVE=y
# CONFIG_NRF24_TX_DISABLE_AUTO_ACK_TEST is not set
# CONFIG_NRF24_PIN_TEST_MODE is not set
CONFIG_NRF24_PIN_TEST_PERIOD_MS=500
CONFIG_NRF24_LOG_LEVEL_VERBOSE=y
